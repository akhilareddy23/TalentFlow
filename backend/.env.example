PORT=5000

# MongoDB Connection String Format:
# Replace <username> and <password> with your actual database credentials.
# Replace <cluster-url> with your MongoDB host/cluster address.

# Option A: MongoDB Atlas (Cloud Cluster) - Recommended
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/talentflow?retryWrites=true&w=majority

# Option B: Local MongoDB with Authentication enabled
# MONGO_URI=mongodb://<username>:<password>@127.0.0.1:27017/talentflow?authSource=admin

JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development
